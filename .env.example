# Project Vajra - Environment Variables
# Copy this file to .env and fill in your values

# === API Credentials ===
BLOCKCHAIN_API_KEY=your_blockchain_api_key_here

# === Performance Settings ===
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=30

# === Data Processing ===
MAX_TRANSACTIONS_PER_ANALYSIS=10000
CHUNK_SIZE=500

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=vajra_system.log
